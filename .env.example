# --- Clerk (auth) ---
# Crée un compte sur https://clerk.com puis une app
# Copie les keys depuis le dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_a2V5LWphd2Zpc2gtNDcuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_dgmhQ6lhpjLYj8XxPL5P8M1RHbVeovU6c1EPKWf6sw

# --- Convex (DB + file storage) ---
# Lance `npx convex dev` une fois, ça crée le projet et te donne l'URL
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOYMENT=dev:your-project

# --- Google Gemini (agent IA) ---
# Gratuit sur https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza_xxx

# --- Deepgram (transcription) ---
# https://console.deepgram.com → $200 free credits au signup
DEEPGRAM_API_KEY=xxx

# --- Hugging Face (Whisper fallback + MusicGen) ---
# https://huggingface.co/settings/tokens → New token (read)
# Utilisé si DEEPGRAM_API_KEY n'est pas défini (fallback transcription Whisper)
# + génération de musique via MusicGen (facebook/musicgen-small)
HF_API_KEY=hf_xxx

# --- Vercel / Convex deploy ---
# Récupère la clé dans ton dashboard Convex → Settings → Deploy Key
CONVEX_DEPLOY_KEY=xxx

# --- Cloudflare R2 (optionnel, on commence avec Convex storage) ---
# À activer quand >1GB de vidéos stockées
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=edito-media
# R2_PUBLIC_URL=https://media.edito.app
